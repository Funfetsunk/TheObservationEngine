# Wixbury — environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# This file (.env.example) should be committed — it documents required config.

# ─── Database ────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/wixbury"

# ─── Cache ───────────────────────────────────────────────────────────────────

# Redis connection string (used for tick state and BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# ─── Anthropic API ───────────────────────────────────────────────────────────

# Your Anthropic API key — used by the newspaper job and biography updater
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Monthly spend cap in USD — hard limit to prevent runaway costs
# Recommended: start at $20 and raise once usage patterns are understood
ANTHROPIC_MONTHLY_CAP_USD="20"

# ─── Simulation engine ───────────────────────────────────────────────────────

# How many citizens to seed on first run
# Must match the founding design document — do not change after first run
FOUNDING_POPULATION="200"

# Tick rate in milliseconds (1 real minute = 1 sim hour)
# This is duplicated here for ops visibility — the canonical value is in constants.ts
# Do not change this after the simulation has started running
TICK_RATE_MS="60000"

# Simulated founding year — the year the city begins
SIM_FOUNDING_YEAR="1"

# ─── Public API ──────────────────────────────────────────────────────────────

# Port the read-only REST API listens on
API_PORT="3001"

# Secret used to sign any internal service tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET="your-secret-here"

# ─── Web frontend ────────────────────────────────────────────────────────────

# URL of the public API — used by Next.js to fetch data
# In development: http://localhost:3001
# In production: your deployed API URL
NEXT_PUBLIC_API_URL="http://localhost:3001"

# WebSocket URL for the live camera feed
# In development: ws://localhost:3001
# In production: wss://your-deployed-api-url
NEXT_PUBLIC_WS_URL="ws://localhost:3001"

# ─── Environment ─────────────────────────────────────────────────────────────

NODE_ENV="development"

# Log level: debug | info | warn | error
LOG_LEVEL="info"
